/// @description Drawing the banshee radius
draw_self()
if(banshee_scream){
	scream = draw_circle_colour((x + 55),(y+50), 150, scream_color, scream_color,true)
	scream = draw_circle_colour((x + 55),(y+50), 100, scream_color, scream_color,true)
	scream = draw_circle_colour((x + 55),(y+50), 50, scream_color, scream_color,true)
}
